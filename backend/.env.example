# Application
APP_NAME="Solar Feasibility Tool"
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
ALLOWED_ORIGINS=["http://localhost:3000"]

# Database
# Development (SQLite — no setup needed):
DATABASE_URL=sqlite+aiosqlite:///./solar_dev.db
# Production (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/solar_db

# API
API_V1_PREFIX=/api/v1

# CEB 2026 / Mauritius Solar Constants
CEB_EXPORT_TARIFF_RS_KWH=5.10
SOLAR_IRRADIANCE_KWH_M2_DAY=5.2
AVERAGE_SYSTEM_COST_RS_WP=55.0
